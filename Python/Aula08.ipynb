    "\n",
    "name = input('whats your name, please: ') \n",
    "note = float(input('write your note: '))\n",
    "\n",
    "if note > med : \n",
    "    print(\"student approved\")\n",
    "else:\n",
    "    note < med \n",
    "    print('failed ')\n",
    "\n",
    "print(f'{name}  {note}')"
